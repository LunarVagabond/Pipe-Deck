{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pipe Deck",
  "version": "0.0.2",
  "identifier": "com.pipedeck.PipeDeck",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pipe Deck",
        "width": 1100,
        "height": 720,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "bin/pipe-deck-daemon"
    ],
    "resources": [
      "packaging/pipe-deck-daemon.service"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "pipewire",
          "wireplumber",
          "pipewire-pulse | pulseaudio-utils"
        ],
        "files": {
          "/usr/lib/systemd/user/pipe-deck-daemon.service": "packaging/pipe-deck-daemon.service",
          "/usr/share/applications/com.pipedeck.PipeDeck.desktop": "../packaging/com.pipedeck.PipeDeck.desktop",
          "/usr/share/metainfo/com.pipedeck.PipeDeck.metainfo.xml": "../packaging/com.pipedeck.PipeDeck.metainfo.xml"
        }
      },
      "rpm": {
        "depends": [
          "pipewire",
          "wireplumber",
          "pipewire-pulse"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/LunarVagabond/Pipe-Deck/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyQzQ2RjM0MDQ0RjU1NEYKUldSUFZVOEVORy9FSXRwVHNOYVVwZytBaHgrVldtWDJHVE1mcHlzR2ZBMnJpZ3lkbjBvOXZGREUK"
    }
  }
}
