# -----------------------------------------------------------------------------
# Pipe Deck — generated artifacts, dependencies, secrets, and local tooling
# -----------------------------------------------------------------------------
.vscode/
# Dependencies
node_modules/

# Frontend build output
dist/
dist-ssr/

# Rust / Tauri
src-tauri/target/
src-tauri/src-tauri/
src-tauri/bin/

# Environment and secrets
.env
.env.*
!.env.example
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test and coverage output
coverage/
.nyc_output/
*.lcov

# Caches and incremental build metadata
.cache/
.parcel-cache/
.sass-cache/
.turbo/
.vite/
*.tsbuildinfo
.eslintcache
.stylelintcache

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor and IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.iml
.fleet/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# Vim / Emacs swap files
*.swp
*.swo
*~
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# Windows / Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Desktop bundle artifacts (usually under target/, but ignore if copied elsewhere)
*.deb
*.rpm
*.AppImage
*.dmg
*.msi
*.exe

# Debug and profiling
*.prof
*.profraw
criterion/

# Patch and merge leftovers
*.orig
*.rej

# Optional local scratch
tmp/
temp/
scratch/
